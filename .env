# =============================================================================
# Yocto Docker ビルド環境 - 環境変数設定
# このファイルを編集してください。スクリプト本体は変更不要です。
# =============================================================================

# ── Docker / Compose 設定 ──────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=yocto_project   # プロジェクト名(全て小文字)
CONTAINER_NAME=Docker_Yocto

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=yocto_docker.sh

VOLUME=./build
WS=build

CPU_CORE=4

# ── Yocto バージョン ───────────────────────────────────────────────────────
# https://wiki.yoctoproject.org/wiki/Releases で最新リリースを確認
# scarthgap = Yocto 5.0 LTS (2024-2026)
# kirkstone  = Yocto 4.0 LTS (2022-2024)
YOCTO_RELEASE=scarthgap

# ── デバイスプロファイル ───────────────────────────────────────────────────
# 以下のどれかを設定してください。MACHINE / IMAGE は自動で決まります。
#
#   x86_64        … PC / VM / USB (x86 64bit)          ← デフォルト
#   rpi4          … Raspberry Pi 4
#   rpi3          … Raspberry Pi 3
#   qemux86_64    … QEMU 仮想マシン(動作確認用)
#
DEVICE_PROFILE=x86_64

# ── ターゲット手動上書き(通常は変更不要) ────────────────────────────────
# DEVICE_PROFILE を設定した場合は以下を空欄にしてください。
# 特殊な MACHINE を使いたい場合のみ直接記入します。
MACHINE=

# ── ベースイメージ ────────────────────────────────────────────────────────
# 空欄にすると DEVICE_PROFILE のデフォルト (core-image-full-cmdline) が使われます。
#
# core-image-minimal      … busybox + systemd のみ。最小構成。ストレージ節約したい場合。
#                           nano / curl / bash すら入っていないため opkg で随時追加が必要。
#
# core-image-base         … minimal + シリアルコンソール対応。組み込み向け。
#                           ほぼ minimal と同じで、GUI や多くのツールは含まない。
#
# core-image-full-cmdline … bash, util-linux, coreutils, ssh-client 等が含まれる実用的な CLI 環境。
#                           一般的な開発・運用用途にはこれを推奨。← デフォルト
#
IMAGE=

# ── USB 書き込みサイズ制限 ────────────────────────────────────────────────
# rootfs パーティションの上限サイズを MB 単位で指定します。
#   0  → デバイス全容量を使う(デフォルト)
#   正の整数 → 指定 MB に制限(例: 8192 = 8GB)
USB_SIZE_MB=0

# ── ネットワーク設定(rootfs に焼き込まれる) ─────────────────────────────
# 静的IPを使う場合は NETWORK_PROTO=static にして以下も設定
NETWORK_PROTO=dhcp

# static の場合のみ設定
STATIC_IP=192.168.1.100
STATIC_NETMASK=255.255.255.0
STATIC_GATEWAY=192.168.1.1
STATIC_DNS=8.8.8.8,8.8.4.4

# ── ロケール・タイムゾーン ─────────────────────────────────────────────────
TIME_ZONE=Asia/Tokyo
LOCALE=en_US.UTF-8

# ── SSH設定 ───────────────────────────────────────────────────────────────
ENABLE_SSH=true
SSH_PORT=22

# ── rootパスワード ────────────────────────────────────────────────────────
ROOT_PASSWORD=password

# ── 追加パッケージ(スペース区切り) ──────────────────────────────────────
# Yocto レシピ名で指定。ここに書いたパッケージはビルド時に rootfs へ組み込まれます。
EXTRA_PACKAGES=nano

# ── 以下はデフォルトインストール済み(変更不要) ──────────────────────────
# 下記は yocto_docker.sh 内で自動的に組み込まれるため、EXTRA_PACKAGES への記載は不要です。
#
# [SSH]
#   openssh            … SSH サーバー本体
#   openssh-sshd       … sshd デーモン
#   openssh-sftp-server… SFTP サポート
#
# [core-image-full-cmdline に含まれる主なもの]
#   bash               … Bash シェル
#   coreutils          … ls, cp, mv, cat 等の基本コマンド (GNU 版)
#   util-linux         … fdisk, mount, lsblk 等
#   procps             … ps, top, free 等
#   iproute2           … ip コマンド (ifconfig の代替)
#   iputils            … ping
#   openssh-ssh        … SSH クライアント
#   packagegroup-core-full-cmdline … 上記をまとめたグループ
