# =============================================================================
# Yocto Docker ビルド環境 - 環境変数設定
# このファイルを編集してください。スクリプト本体は変更不要です。
# =============================================================================

# ── Docker / Compose 設定 ──────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=yocto_project   # プロジェクト名(全て小文字)
CONTAINER_NAME=Docker_Yocto

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=yocto_docker.sh

VOLUME=./build
WS=build

CPU_CORE=4

# ── ホスト UID/GID (./build ボリュームの権限合わせ) ───────────────────────
# 以下のコマンドで確認して設定してください:
#   echo "HOST_UID=$(id -u)"
#   echo "HOST_GID=$(id -g)"
# 未設定の場合は Dockerfile の ARG デフォルト (1000) が使われます。
HOST_UID=1000
HOST_GID=1000

# ── Yocto バージョン ───────────────────────────────────────────────────────
# https://wiki.yoctoproject.org/wiki/Releases で最新リリースを確認
# scarthgap = Yocto 5.0 LTS (2024-2026)
# kirkstone  = Yocto 4.0 LTS (2022-2024)
YOCTO_RELEASE=scarthgap

# ── デバイスプロファイル ───────────────────────────────────────────────────
# 以下のどれかを設定してください。MACHINE / IMAGE は自動で決まります。
#
#   x86_64        … PC / VM / USB (x86 64bit)          ← デフォルト
#   rpi4          … Raspberry Pi 4
#   rpi3          … Raspberry Pi 3
#   qemux86_64    … QEMU 仮想マシン(動作確認用)
#
DEVICE_PROFILE=x86_64

# ── ターゲット手動上書き(通常は変更不要) ────────────────────────────────
# DEVICE_PROFILE を設定した場合は以下を空欄にしてください。
# 特殊な MACHINE を使いたい場合のみ直接記入します。
MACHINE=

# ── ベースイメージ ────────────────────────────────────────────────────────
# 空欄にすると DEVICE_PROFILE のデフォルト (core-image-full-cmdline) が使われます。
#
# core-image-minimal      … busybox + systemd のみ。最小構成。ストレージ節約したい場合。
#                           nano / curl / bash すら入っていないため opkg で随時追加が必要。
#
# core-image-base         … minimal + シリアルコンソール対応。組み込み向け。
#                           ほぼ minimal と同じで、GUI や多くのツールは含まない。
#
# core-image-full-cmdline … bash, util-linux, coreutils, ssh-client 等が含まれる実用的な CLI 環境。
#                           一般的な開発・運用用途にはこれを推奨。← デフォルト
#
IMAGE=

# ── USB 書き込みサイズ制限 ────────────────────────────────────────────────
# rootfs パーティションの上限サイズを MB 単位で指定します。
#   0  → デバイス全容量を使う(デフォルト)
#   正の整数 → 指定 MB に制限(例: 8192 = 8GB)
USB_SIZE_MB=0

# ── ネットワーク設定(rootfs に焼き込まれる) ─────────────────────────────
# 静的IPを使う場合は NETWORK_PROTO=static にして以下も設定
NETWORK_PROTO=dhcp

# static の場合のみ設定
STATIC_IP=192.168.1.100
STATIC_NETMASK=255.255.255.0
STATIC_GATEWAY=192.168.1.1
STATIC_DNS=8.8.8.8,8.8.4.4

# ── ロケール・タイムゾーン ─────────────────────────────────────────────────
TIME_ZONE=Asia/Tokyo
LOCALE=en_US.UTF-8

# ── SSH設定 ───────────────────────────────────────────────────────────────
ENABLE_SSH=true
SSH_PORT=22

# ── rootパスワード ────────────────────────────────────────────────────────
ROOT_PASSWORD=password

# ── 追加パッケージ(スペース区切り) ──────────────────────────────────────
# Yocto レシピ名で指定。ここに書いたパッケージはビルド時に rootfs へ組み込まれます。
# 詳しくはREADMEの「インストールされるパッケージ」を参照してください。
#
# デフォルトでインストール済みの主なパッケージ:
#   busybox, bash, coreutils, util-linux, procps, iproute2, iputils,  # 基本コマンド群
#   openssh (sshd/sftp/client), sudo, gzip, bzip2, tar,               # SSH・圧縮
#   make, diffutils, patch, grep, sed, gawk, findutils,               # 開発ツール
#   opkg, opkg-collateral,                                            # パッケージマネージャー
#   ※ 詳細は README.md 参照
#

# networkmanager を指定すると yocto_docker.sh が自動で以下を処理します:
#   - connman の除外 (競合回避)
#   - DISTRO_FEATURES への networkmanager / systemd 追加
#   - VIRTUAL-RUNTIME_net_manager = "networkmanager" の設定
#   - SYSTEMD_AUTO_ENABLE / SYSTEMD_AUTO_ENABLE:pn-networkmanager の制御
#   - NETWORK_PROTO=static の場合は NM キーファイルを rootfs に生成
#   - NETWORK_PROTO=dhcp  の場合は NM デフォルト動作に委譲 (設定ファイル不要)
EXTRA_PACKAGES=nano opkg opkg-collateral tzdata networkmanager networkmanager-nmcli grub grub-efi

# minimal用 (USE_SYSTEMD=true と合わせて使う)
# EXTRA_PACKAGES=nano opkg opkg-collateral tzdata shadow openssl gawk coreutils libpam networkmanager networkmanager-nmcli grub grub-efi

# ── 追加レイヤー(スペース区切りで複数指定可) ─────────────────────────────
# 書式: "レイヤ名,GitリポURL[,ブランチ[,サブパス]]"  をスペース区切りで並べる
# ブランチを省略すると YOCTO_RELEASE と同じブランチを使用します。
# サブパスを指定すると bblayers.conf に /{WS}/レイヤ名/サブパス で登録されます。
# (meta-openembedded のようなモノレポで使用)
#
# パッケージとレイヤーの対応:
#   nano           → meta-oe          (サブパス: meta-oe)
#   networkmanager → meta-networking  (サブパス: meta-networking)
#                    ※ meta-oe / meta-python も依存レイヤーとして必要
#
EXTRA_LAYERS=meta-openembedded,https://github.com/openembedded/meta-openembedded,,meta-oe meta-openembedded,https://github.com/openembedded/meta-openembedded,,meta-python meta-openembedded,https://github.com/openembedded/meta-openembedded,,meta-networking

# ── ソースミラー設定 ───────────────────────────────────────────────────────
# ftpmirror.gnu.org が不安定な場合の代替ミラーを設定します。
# 複数指定する場合はスペース区切りで並べてください。
# Yocto は上から順に試し、成功したミラーを使います。
#
# 書式: "元URL_パターン ミラーURL" をスペース区切りで複数並べる
#   例(1件): "https://ftpmirror.gnu.org/gnu/.* https://ftp.gnu.org/gnu/"
#   例(複数): "https://ftpmirror.gnu.org/gnu/.* https://ftp.gnu.org/gnu/ ftp://ftp.gnu.org/gnu/.* https://ftp.gnu.org/gnu/"
#
# PREMIRRORS … bitbake が upstream より先に試すミラー (高速化・安定化向け)
# MIRRORS    … upstream が失敗したときのフォールバック
#
# GNU 公式ミラーリスト: https://www.gnu.org/prep/ftp.html
# Yocto 公式ミラー:     https://downloads.yoctoproject.org/mirror/sources/
#
# 空欄にするとミラー設定を追加しません（Yocto 組み込みミラーのみ使用）。
PREMIRRORS=https://ftpmirror.gnu.org/gnu/.* https://ftp.gnu.org/gnu/ ftp://ftp.gnu.org/gnu/.* https://ftp.gnu.org/gnu/ https://ftpmirror.gnu.org/gnu/.* https://downloads.yoctoproject.org/mirror/sources/
MIRRORS=

# ── フェッチリトライ回数 ───────────────────────────────────────────────────
# ミラーが不安定な場合に何回までリトライするかを指定します。
# bitbake の BB_FETCH_RETRIES に対応しています（デフォルト: 5）。
FETCH_RETRIES=5

# ── systemd init manager ──────────────────────────────────────────────────
# true  … systemd を init manager として使用 (minimal では必須)
# false … デフォルト (full-cmdline は systemd 前提のため変更不要)
USE_SYSTEMD=false